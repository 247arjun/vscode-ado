{
  "name": "azure-devops-queries",
  "displayName": "Azure DevOps Queries",
  "description": "View Azure DevOps queries as a grouped tree in VS Code",
  "version": "1.3.0",
  "publisher": "ArjunGopalakrishna",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/247arjun/vscode-ado.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:adoQueries.results"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adoQueries",
          "title": "Azure DevOps Queries",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "adoQueries": [
        {
          "id": "adoThings.navigator",
          "name": "Tasks"
        },
        {
          "id": "adoQueries.results",
          "name": "Query Results"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "adoQueries.results",
        "contents": "No Azure DevOps queries configured.\n[Add Query from Clipboard](command:adoQueries.setQueryFromClipboard)\n[Add Query Manually](command:adoQueries.setQueryManual)\nCopy a query URL from Azure DevOps, then click \"Add Query from Clipboard\" to get started.\n[Learn More](command:adoQueries.showOutput)",
        "when": "adoQueries.signedIn"
      },
      {
        "view": "adoQueries.results",
        "contents": "Sign in to Azure DevOps to sync your work items.\n[Sign in to Azure DevOps](command:adoQueries.signIn)\nUses your existing VS Code Microsoft account — no personal access token required."
      }
    ],
    "commands": [
      {
        "command": "adoQueries.setQueryFromClipboard",
        "title": "Azure DevOps: Add Query From Clipboard"
      },
      {
        "command": "adoQueries.setQueryManual",
        "title": "Azure DevOps: Add Query"
      },
      {
        "command": "adoQueries.setGroupBy",
        "title": "Azure DevOps: Configure Grouping"
      },
      {
        "command": "adoQueries.refresh",
        "title": "Azure DevOps: Refresh Queries",
        "icon": "$(refresh)"
      },
      {
        "command": "adoQueries.refreshQuery",
        "title": "Refresh This Query",
        "icon": "$(refresh)"
      },
      {
        "command": "adoQueries.openWorkItem",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "adoQueries.openQueryInBrowser",
        "title": "Open Query in Browser"
      },
      {
        "command": "adoQueries.copyWorkItemId",
        "title": "Copy Work Item ID"
      },
      {
        "command": "adoQueries.copyWorkItemUrl",
        "title": "Copy Work Item URL"
      },
      {
        "command": "adoQueries.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "adoQueries.removeQuery",
        "title": "Remove Query"
      },
      {
        "command": "adoQueries.renameQuery",
        "title": "Rename Query"
      },
      {
        "command": "adoQueries.changeState",
        "title": "Change State"
      },
      {
        "command": "adoQueries.showOutput",
        "title": "Azure DevOps: Show Output Log"
      },
      {
        "command": "adoQueries.signIn",
        "title": "Azure DevOps: Sign In"
      },
      {
        "command": "adoThings.open",
        "title": "ADO Things: Open Tasks Workbench",
        "icon": "$(window)"
      },
      {
        "command": "adoThings.openList",
        "title": "ADO Things: Open List"
      },
      {
        "command": "adoThings.quickCapture",
        "title": "ADO Things: Quick Add Task",
        "icon": "$(add)"
      },
      {
        "command": "adoThings.undo",
        "title": "ADO Things: Undo Last Change"
      },
      {
        "command": "adoThings.newProject",
        "title": "ADO Things: New Project"
      },
      {
        "command": "adoThings.newArea",
        "title": "ADO Things: New Area"
      },
      {
        "command": "adoThings.resetDatabase",
        "title": "ADO Things: Reset Local Database"
      },
      {
        "command": "adoThings.pushToAdo",
        "title": "ADO Things: Push Task to Azure DevOps"
      },
      {
        "command": "adoThings.configureDetailFields",
        "title": "ADO Things: Choose Detail Pane Fields",
        "icon": "$(settings-gear)"
      }
    ],
    "keybindings": [
      {
        "command": "adoQueries.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "view.adoQueries.results.visible"
      },
      {
        "command": "adoThings.quickCapture",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      },
      {
        "command": "adoThings.undo",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "adoThings.quickCapture",
          "when": "view == adoThings.navigator",
          "group": "navigation"
        },
        {
          "command": "adoThings.open",
          "when": "view == adoThings.navigator",
          "group": "navigation"
        },
        {
          "command": "adoThings.configureDetailFields",
          "when": "view == adoThings.navigator",
          "group": "1_config"
        },
        {
          "command": "adoQueries.refresh",
          "when": "view == adoQueries.results",
          "group": "navigation"
        },
        {
          "command": "adoQueries.expandAll",
          "when": "view == adoQueries.results",
          "group": "navigation"
        },
        {
          "command": "adoQueries.setQueryFromClipboard",
          "when": "view == adoQueries.results"
        },
        {
          "command": "adoQueries.setGroupBy",
          "when": "view == adoQueries.results"
        },
        {
          "command": "adoQueries.showOutput",
          "when": "view == adoQueries.results"
        }
      ],
      "view/item/context": [
        {
          "command": "adoQueries.openWorkItem",
          "when": "view == adoQueries.results && viewItem == workItem",
          "group": "inline"
        },
        {
          "command": "adoQueries.refreshQuery",
          "when": "view == adoQueries.results && viewItem == query",
          "group": "inline"
        },
        {
          "command": "adoQueries.copyWorkItemId",
          "when": "view == adoQueries.results && viewItem == workItem",
          "group": "1_copy"
        },
        {
          "command": "adoQueries.copyWorkItemUrl",
          "when": "view == adoQueries.results && viewItem == workItem",
          "group": "1_copy"
        },
        {
          "command": "adoQueries.changeState",
          "when": "view == adoQueries.results && viewItem == workItem",
          "group": "2_actions"
        },
        {
          "command": "adoQueries.openQueryInBrowser",
          "when": "view == adoQueries.results && viewItem == query",
          "group": "2_query"
        },
        {
          "command": "adoQueries.renameQuery",
          "when": "view == adoQueries.results && viewItem == query",
          "group": "3_manage"
        },
        {
          "command": "adoQueries.removeQuery",
          "when": "view == adoQueries.results && viewItem == query",
          "group": "3_manage"
        }
      ]
    },
    "configuration": {
      "title": "Azure DevOps Queries",
      "properties": {
        "adoQueries.organization": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization name or URL (e.g., 'MyOrg' or 'https://dev.azure.com/MyOrg/')"
        },
        "adoQueries.project": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project name"
        },
        "adoQueries.detectFromGit": {
          "type": "boolean",
          "default": true,
          "description": "Allow CLI to detect org/project from Git repository configuration"
        },
        "adoQueries.queries": {
          "type": "array",
          "default": [],
          "scope": "resource",
          "description": "Array of query definitions. Each query appears as a top-level node in the tree.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this query (custom, not tied to ADO query name)"
              },
              "organization": {
                "type": "string",
                "description": "Azure DevOps organization (overrides global setting)"
              },
              "project": {
                "type": "string",
                "description": "Azure DevOps project (overrides global setting)"
              },
              "queryId": {
                "type": "string",
                "description": "Query GUID"
              },
              "queryPath": {
                "type": "string",
                "description": "Query path (alternative to queryId)"
              },
              "groupBy": {
                "type": "array",
                "description": "Optional per-query grouping. Falls back to global adoQueries.groupBy if not specified.",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": { "type": "string" },
                    "projection": { "type": "string" },
                    "missingLabel": { "type": "string" },
                    "bucket": { "type": "string" }
                  },
                  "required": ["field"]
                }
              },
              "collapsed": {
                "type": "boolean",
                "default": false,
                "description": "Start this query collapsed"
              }
            },
            "required": ["name"]
          }
        },
        "adoQueries.groupBy": {
          "type": "array",
          "default": [
            {
              "field": "System.State",
              "missingLabel": "(no state)"
            }
          ],
          "description": "Array of grouping specifications (up to 5 levels)",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "description": "Work item field reference name"
              },
              "projection": {
                "type": "string",
                "description": "For identity fields, which property to use (e.g., displayName)"
              },
              "missingLabel": {
                "type": "string",
                "description": "Label to show when field value is missing"
              },
              "bucket": {
                "type": "string",
                "enum": ["date"],
                "description": "Bucketing strategy"
              },
              "dateBucket": {
                "type": "string",
                "description": "Date bucket categories (overdue|today|thisWeek|future|none)"
              }
            },
            "required": ["field"]
          }
        },
        "adoQueries.maxItems": {
          "type": "integer",
          "default": 500,
          "description": "Maximum number of work items to fetch"
        },
        "adoQueries.refreshIntervalSeconds": {
          "type": "integer",
          "default": 0,
          "description": "Auto-refresh interval in seconds (0 = manual only)"
        },
        "adoQueries.cacheTtlSeconds": {
          "type": "integer",
          "default": 30,
          "description": "Cache time-to-live in seconds"
        },
        "adoQueries.batchSize": {
          "type": "integer",
          "default": 200,
          "description": "Batch size for fetching work items (max 200)"
        },
        "adoQueries.detailFields": {
          "type": "array",
          "default": [],
          "markdownDescription": "Fields to show in the task detail pane, in order. Leave empty to use the default set. Use ADO field reference names (e.g. `System.AssignedTo`) or local keys (`local.when`, `local.deadline`, `local.tags`).",
          "items": {
            "type": "string",
            "enum": [
              "System.Description",
              "System.State",
              "System.Reason",
              "System.AssignedTo",
              "System.AreaPath",
              "System.IterationPath",
              "Microsoft.VSTS.Common.Priority",
              "Microsoft.VSTS.Common.Severity",
              "Microsoft.VSTS.Scheduling.StoryPoints",
              "Microsoft.VSTS.Scheduling.Effort",
              "Microsoft.VSTS.Scheduling.RemainingWork",
              "Microsoft.VSTS.Scheduling.OriginalEstimate",
              "Microsoft.VSTS.Scheduling.StartDate",
              "Microsoft.VSTS.Scheduling.DueDate",
              "System.Tags",
              "System.CreatedBy",
              "System.CreatedDate",
              "System.ChangedBy",
              "System.ChangedDate",
              "local.when",
              "local.deadline",
              "local.tags"
            ],
            "enumDescriptions": [
              "ADO rich-text description",
              "Work item state (read-only here; change via the row action)",
              "Reason (editable)",
              "Assigned identity",
              "Area path",
              "Iteration path",
              "Priority 1–4 (editable)",
              "Severity (editable)",
              "Story points (editable)",
              "Effort (editable)",
              "Remaining work (editable)",
              "Original estimate (editable)",
              "Start date (editable)",
              "Due date (editable)",
              "ADO tags (editable)",
              "Created by",
              "Created date",
              "Changed by",
              "Changed date",
              "Local do-date (editable)",
              "Local deadline (editable)",
              "Local tags"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
